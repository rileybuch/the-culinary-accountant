---
---

<section id="gallery" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-secondary uppercase tracking-[0.25em] text-xs font-semibold mb-5">Our Work</p>
      <h2 class="font-display text-4xl md:text-5xl text-charcoal mb-5 leading-tight">
        Every Dish Tells a Story
      </h2>
      <p class="text-charcoal/55 max-w-md mx-auto leading-relaxed">
        From intimate dinner parties to grand celebrations, a glimpse of what we bring to the table.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="aspect-[4/3] rounded-xl overflow-hidden">
        <img src="/images/gallery/cookie.JPG" alt="Chocolate tarts" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-xl overflow-hidden">
        <img src="/images/gallery/cookies_2.jpg" alt="Cookie" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-xl overflow-hidden">
        <img src="/images/gallery/cookies_3.jpg" alt="Assorted cookies" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-xl overflow-hidden">
        <img src="/images/gallery/cookies_5.JPG" alt="Assorted cookies" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-xl overflow-hidden">
        <img src="/images/gallery/cookies_6.JPG" alt="Cupcakes" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-xl overflow-hidden">
        <img src="/images/gallery/cupcakes_2.JPG" alt="Cupcakes" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</section>
