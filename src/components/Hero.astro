---
---

<section
  id="home"
  class="relative min-h-screen flex items-center justify-center text-center overflow-hidden"
  style="background: linear-gradient(150deg, #162b09 0%, #2D5A1B 45%, #1a3a0a 100%);"
>
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="relative z-10 px-6 max-w-4xl mx-auto">
    <p class="text-secondary uppercase tracking-[0.35em] text-xs font-semibold mb-8">
      Charlotte, North Carolina
    </p>
    <h1 class="font-display text-5xl md:text-7xl lg:text-8xl text-cream font-bold leading-[1.05] mb-6">
      The Culinary<br />Accountant
    </h1>
    <p class="text-cream/60 text-lg md:text-xl max-w-xl mx-auto mb-12 leading-relaxed font-light">
      Precision-crafted catering for every occasion —<br class="hidden md:block" />
      where every detail is accounted for.
    </p>
    <a
      href="#services"
      class="inline-block bg-secondary text-charcoal font-semibold px-10 py-4 rounded text-xs uppercase tracking-[0.2em] hover:bg-secondary/90 transition-colors"
    >
      Explore Our Services
    </a>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-cream/20 animate-bounce">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="12" y1="5" x2="12" y2="19"></line>
      <polyline points="19 12 12 19 5 12"></polyline>
    </svg>
  </div>
</section>
