<section
  id="contact"
  class="py-28 text-center"
  style="background: linear-gradient(150deg, #162b09 0%, #2D5A1B 45%, #1a3a0a 100%);"
>
  <div class="max-w-2xl mx-auto px-6">
    <p class="text-secondary uppercase tracking-[0.25em] text-xs font-semibold mb-5">Get in Touch</p>
    <h2 class="font-display text-4xl md:text-5xl text-cream mb-6 leading-tight">
      Let's Create Something Memorable
    </h2>
    <p class="text-cream/55 text-lg leading-relaxed mb-12">
      Ready to plan your next event? We'd love to hear from you.<br class="hidden md:block" />
      Contact details coming soon — check back shortly.
    </p>
    <div class="inline-flex items-center gap-3 bg-cream/10 border border-cream/15 rounded-full px-8 py-4 text-cream/60 text-sm">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
        <circle cx="12" cy="9" r="2.5" />
      </svg>
      <span>Charlotte, North Carolina</span>
    </div>
  </div>
</section>
