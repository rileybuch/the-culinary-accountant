---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 bg-cream/95 backdrop-blur border-b border-primary/10 shadow-sm">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="font-display text-lg font-semibold text-primary tracking-wide">
      The Culinary Accountant
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-charcoal/60 hover:text-primary transition-colors text-sm font-medium tracking-widest uppercase"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 -mr-2"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-px bg-primary"></span>
      <span class="block w-6 h-px bg-primary"></span>
      <span class="block w-4 h-px bg-primary"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-primary/10 bg-cream">
    <ul class="flex flex-col px-6 py-5 gap-5">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-charcoal/60 hover:text-primary transition-colors text-sm font-medium tracking-widest uppercase"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
